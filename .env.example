# ButterCMS read token. Leave empty to use the bundled content (src/content/knowledge-base.json).
# Get a token at https://buttercms.com/ -> Settings -> API Tokens (Read).
VITE_BUTTER_TOKEN=

# Slug of the ButterCMS "Page" that holds the Start-Here guide (optional).
VITE_BUTTER_GUIDE_SLUG=start-here

# Key of the ButterCMS "Collection" that holds the domains (optional).
VITE_BUTTER_DOMAINS_KEY=domains
